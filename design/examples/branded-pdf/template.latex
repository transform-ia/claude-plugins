%% ============================================================
%% Acme Corp Branded PDF Template
%% For use with Pandoc + pdflatex (no XeTeX required)
%% Run: bash generate.sh
%% Ubuntu install:
%%   sudo apt install texlive texlive-latex-extra \
%%                   texlive-fonts-recommended texlive-fonts-extra pandoc
%% ============================================================

\documentclass[
  $if(fontsize)$$fontsize$,$endif$
  a4paper,
  oneside
]{article}

%% ============================================================
%% ENCODING (must come first for pdflatex)
%% ============================================================
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}

%% ============================================================
%% CORE PACKAGES
%% ============================================================
\usepackage[dvipsnames,svgnames,x11names]{xcolor}
\usepackage{geometry}
\usepackage{microtype}
\usepackage{graphicx}
\usepackage{tikz}
\usepackage{float}
\usepackage{caption}
\usepackage{setspace}
\usepackage[skip=0.5em,indent=0pt]{parskip}

%% ============================================================
%% BRAND COLORS — primary: #003366
%% ============================================================
\definecolor{BrandPrimary}{HTML}{003366}
\definecolor{BrandDark}{HTML}{001F3F}
\definecolor{BrandMid}{HTML}{0055AA}
\definecolor{BrandLight}{HTML}{CCE0FF}
\definecolor{BrandPale}{HTML}{EEF4FF}
\definecolor{CodeBg}{HTML}{F6F8FA}
\definecolor{LinkColor}{HTML}{0055BB}
\definecolor{TableHead}{HTML}{003366}
\definecolor{RuleColor}{HTML}{C0D4E8}
\definecolor{TextMain}{HTML}{1C1C2E}
\definecolor{TextMuted}{HTML}{6C7280}
\definecolor{QuoteBg}{HTML}{F0F5FF}
\definecolor{QuoteBar}{HTML}{0066CC}

%% ============================================================
%% PAGE GEOMETRY — 1.5in margins all sides
%% ============================================================
\geometry{
  top=1.5in,
  bottom=1.5in,
  left=1.5in,
  right=1.5in,
  headheight=16pt,
  includeheadfoot
}

%% ============================================================
%% FONTS (pdflatex-compatible)
%% helvet  → Helvetica-like sans-serif (simulates Helvetica Neue)
%% inconsolata → clean monospace for code
%% lmodern → Latin Modern for math and fallback
%% ============================================================
\usepackage{lmodern}
\usepackage[scaled=0.92]{helvet}
\usepackage[scaled=0.85]{inconsolata}

%% Use sans-serif (Helvetica) as the default document typeface
\renewcommand\familydefault{\sfdefault}

%% ============================================================
%% LINE SPACING
%% ============================================================
\setstretch{1.3}

%% ============================================================
%% HEADERS & FOOTERS
%% Left: mini logo | Center: company | Right: doc title
%% Footer: date | confidential | page N / total
%% ============================================================
\usepackage{fancyhdr}
\usepackage{lastpage}
\pagestyle{fancy}
\fancyhf{}

\fancyhead[L]{%
  \begin{tikzpicture}[baseline=(t.base)]%
    \fill[BrandPrimary] (0,0) rectangle (0.60cm,0.38cm);%
    \node[text=white,font=\tiny\bfseries\sffamily,inner sep=0pt]
      (t) at (0.30cm,0.19cm) {ACME};%
  \end{tikzpicture}%
}
\fancyhead[C]{\small\sffamily\textcolor{TextMuted}{Acme Corp}}
\fancyhead[R]{\small\sffamily\textcolor{TextMuted}{$if(title)$$title$$endif$}}
\fancyfoot[L]{\small\sffamily\textcolor{TextMuted}{$if(date)$$date$$endif$}}
\fancyfoot[C]{\small\sffamily\textcolor{TextMuted}{Confidential}}
\fancyfoot[R]{%
  \small\sffamily\textbf{\textcolor{BrandPrimary}{\thepage{} / \pageref*{LastPage}}}%
}
\renewcommand{\headrulewidth}{0.5pt}
\renewcommand{\headrule}{%
  {\color{BrandPrimary}\hrule width\headwidth height 0.5pt}}
\renewcommand{\footrulewidth}{0.3pt}
\renewcommand{\footrule}{%
  {\color{RuleColor}\hrule width\headwidth height 0.3pt}}
\fancypagestyle{plain}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

%% ============================================================
%% TABLE OF CONTENTS
%% ============================================================
\usepackage{tocloft}
\renewcommand{\cfttoctitlefont}{\Large\bfseries\sffamily\color{BrandPrimary}}
\renewcommand{\cftsecfont}{\sffamily}
\renewcommand{\cftsubsecfont}{\sffamily\small}
\renewcommand{\cftsecpagefont}{\sffamily\bfseries\color{BrandPrimary}}
\renewcommand{\cftsubsecpagefont}{\sffamily\small\color{BrandMid}}
\setlength{\cftbeforesecskip}{0.4em}

%% ============================================================
%% SECTION TITLE STYLING
%% ============================================================
\usepackage{titlesec}

% H1 — numbered badge + blue underrule
\titleformat{\section}{%
  \Large\bfseries\sffamily\color{BrandPrimary}%
}{%
  \colorbox{BrandPrimary}{\color{white}\,\thesection\,}%
}{0.5em}{}[%
  \vspace{0.1em}{\color{BrandMid}\rule{\linewidth}{1.5pt}}%
]
\titlespacing*{\section}
  {0pt}{2.5ex plus 0.5ex minus 0.2ex}{1.2ex plus 0.2ex}

% H2 — subtle underrule
\titleformat{\subsection}{%
  \large\bfseries\sffamily\color{BrandPrimary}%
}{\thesubsection}{0.6em}{}[%
  \vspace{0.1em}{\color{RuleColor}\rule{\linewidth}{0.6pt}}%
]
\titlespacing*{\subsection}{0pt}{2.0ex plus 0.3ex}{0.8ex}

% H3
\titleformat{\subsubsection}{%
  \normalsize\bfseries\sffamily\color{BrandMid}%
}{\thesubsubsection}{0.5em}{}
\titlespacing*{\subsubsection}{0pt}{1.5ex plus 0.2ex}{0.5ex}

% H4 (run-in)
\titleformat{\paragraph}[runin]{%
  \normalsize\bfseries\sffamily\color{TextMain}%
}{}{0em}{}[.\quad]
\titlespacing*{\paragraph}{0pt}{1.2ex}{0.3em}

% H5 (run-in, italic)
\titleformat{\subparagraph}[runin]{%
  \small\bfseries\itshape\color{TextMuted}%
}{}{0em}{}[.\quad]
\titlespacing*{\subparagraph}{0pt}{1.0ex}{0.3em}

%% ============================================================
%% TABLES — booktabs with colortbl for header rows
%% ============================================================
\usepackage{booktabs}
\usepackage{longtable}
\usepackage{array}
\usepackage{multirow}
\usepackage{colortbl}
\usepackage{tabularx}
\arrayrulecolor{RuleColor}

%% ============================================================
%% CODE BLOCKS
%% Pandoc wraps highlighted code in Shaded > Highlighting.
%% $highlighting-macros$ defines Shaded as empty; we override it.
%% ============================================================
\usepackage{fancyvrb}
\usepackage[breakable,skins,listings]{tcolorbox}

$if(highlighting-macros)$
$highlighting-macros$
$endif$

\renewenvironment{Shaded}{%
  \begin{tcolorbox}[
    breakable,
    enhanced,
    colback=CodeBg,
    frame empty,
    leftrule=3pt,
    left=5pt, right=5pt, top=4pt, bottom=4pt,
    colframe=BrandMid,
    arc=2pt,
    outer arc=2pt,
    before upper={\setstretch{1.1}},
    fontupper=\small\ttfamily
  ]%
}{%
  \end{tcolorbox}%
}

% Inline code: colour + reduced size, safe in all contexts
\let\OrigTexttt\texttt
\renewcommand{\texttt}[1]{%
  \ifmmode\mathtt{#1}\else%
    {\small\OrigTexttt{\textcolor{BrandDark}{#1}}}%
  \fi%
}

%% ============================================================
%% BLOCKQUOTES — left-bar with pale blue background
%% ============================================================
\usepackage{mdframed}
\newmdenv[
  topline=false,
  bottomline=false,
  rightline=false,
  linewidth=3pt,
  linecolor=QuoteBar,
  backgroundcolor=QuoteBg,
  innerleftmargin=14pt,
  innerrightmargin=10pt,
  innertopmargin=8pt,
  innerbottommargin=8pt,
  skipabove=\baselineskip,
  skipbelow=\baselineskip
]{BrandQuote}

\renewenvironment{quote}{%
  \begin{BrandQuote}\itshape\color{TextMain}%
}{%
  \end{BrandQuote}%
}

%% ============================================================
%% LISTS — branded bullet and number colors
%% ============================================================
\usepackage{enumitem}
\setlist[itemize]{
  leftmargin=*,
  label=\textcolor{BrandMid}{\textbullet},
  itemsep=0.15em,
  parsep=0pt
}
\setlist[itemize,2]{label=\textcolor{BrandMid}{\textendash}}
\setlist[itemize,3]{label=\textcolor{BrandLight}{\textasteriskcentered}}
\setlist[enumerate]{
  leftmargin=*,
  label=\textcolor{BrandPrimary}{\arabic*.},
  itemsep=0.15em,
  parsep=0pt
}

% Required by Pandoc for tight lists
\providecommand{\tightlist}{%
  \setlength{\itemsep}{2pt}\setlength{\parskip}{0pt}%
}

%% ============================================================
%% FIGURES
%% ============================================================
\captionsetup{
  font={small,it,color=TextMuted},
  labelfont={bf,color=BrandPrimary},
  labelsep=period,
  skip=6pt,
  justification=centering
}
\makeatletter\def\fps@figure{H}\makeatother

%% ============================================================
%% MATH
%% ============================================================
\usepackage{amsmath}
\usepackage{amssymb}

%% ============================================================
%% FOOTNOTES
%% ============================================================
\usepackage[bottom,hang,multiple]{footmisc}
\setlength{\footnotemargin}{0.5em}
\renewcommand{\footnoterule}{%
  \kern-3pt%
  {\color{RuleColor}\hrule width 0.45\textwidth height 0.4pt}%
  \kern2.5pt%
}

%% ============================================================
%% STRIKETHROUGH (Pandoc uses \sout from ulem)
%% ============================================================
\usepackage[normalem]{ulem}

%% ============================================================
%% HYPERLINKS — load near-last
%% ============================================================
\usepackage{hyperref}
\hypersetup{
  colorlinks=true,
  allcolors=LinkColor,
  linkcolor=BrandMid,
  citecolor=BrandMid,
  urlcolor=LinkColor,
  pdftitle={$if(title)$$title$$endif$},
  pdfauthor={$for(author)$$author$$sep$, $endfor$},
  pdfsubject={$if(subtitle)$$subtitle$$endif$},
  pdfkeywords={$if(keywords)$$for(keywords)$$keywords$$sep$, $endfor$$endif$},
  pdfpagemode=UseOutlines,
  bookmarksopen=true,
  bookmarksnumbered=true,
  pdfstartview=FitH
}
\usepackage{nameref}

%% ============================================================
%% YAML HEADER-INCLUDES PASSTHROUGH
%% ============================================================
$for(header-includes)$
$header-includes$
$endfor$

%% ============================================================
%% BRANDED TITLE PAGE
%% Deep blue background, circular logo placeholder, centered layout
%% ============================================================
\newcommand{\maketitlecustom}{%
  \begin{titlepage}
    \pagecolor{BrandPrimary}
    \color{white}
    \setstretch{1}
    \vspace*{1.5cm}
    %% Logo placeholder — swap for \includegraphics[width=5cm]{logo.png}
    \begin{center}
      \begin{tikzpicture}
        \draw[white,line width=3pt] (0,0) circle (2.2cm);
        \fill[white] (0,0) circle (1.75cm);
        \node[text=BrandPrimary,
              font=\fontsize{40}{44}\selectfont\bfseries\sffamily]
          at (0,0) {A};
      \end{tikzpicture}
    \end{center}
    \vspace{0.6cm}
    \begin{center}
      {\fontsize{30}{36}\selectfont\bfseries\sffamily ACME CORP}\\[0.4em]
      {\large\sffamily\itshape Building Tomorrow, Today}
    \end{center}
    \vfill
    \begin{center}
      {\color{BrandLight}\rule{0.75\textwidth}{1pt}}\\[0.8em]
      {\LARGE\bfseries\sffamily
        $if(title)$$title$$else$Untitled$endif$}\\[0.4em]
      $if(subtitle)$
        {\large\sffamily\itshape $subtitle$}\\[0.4em]
      $endif$
      {\color{BrandLight}\rule{0.75\textwidth}{1pt}}
    \end{center}
    \vspace{1.4cm}
    $if(author)$
    \begin{center}
      {\large\sffamily $for(author)$$author$$sep$\\$endfor$}
    \end{center}
    \vspace{0.5em}
    $endif$
    $if(date)$
    \begin{center}{\sffamily $date$}\end{center}
    $endif$
    \vspace{1cm}
  \end{titlepage}
  \pagecolor{white}%
}

%% ============================================================
%% BEGIN DOCUMENT
%% ============================================================
\begin{document}

$if(title)$
\maketitlecustom
\setcounter{page}{1}
$endif$

\pagestyle{fancy}

$if(abstract)$
\begin{mdframed}[
  linecolor=BrandMid,
  linewidth=1pt,
  backgroundcolor=BrandPale,
  innerleftmargin=14pt,
  innerrightmargin=14pt,
  innertopmargin=10pt,
  innerbottommargin=10pt
]
\noindent\textbf{\textcolor{BrandPrimary}{Abstract.}}\enspace $abstract$
\end{mdframed}
\vspace{0.5em}
$endif$

$if(toc)$
{
  \hypersetup{linkcolor=BrandPrimary}
  \setcounter{tocdepth}{$if(toc-depth)$$toc-depth$$else$3$endif$}
  \tableofcontents
  \clearpage
}
$endif$

$body$

\end{document}
