{
  "description": "Debug plugin to capture hook context for analysis",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/sandbox/transform-ia/claude-plugins/test-hook-capture.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/sandbox/transform-ia/claude-plugins/test-hook-capture.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/sandbox/transform-ia/claude-plugins/test-hook-capture.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/sandbox/transform-ia/claude-plugins/test-hook-capture.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
